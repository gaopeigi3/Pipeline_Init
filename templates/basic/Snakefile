configfile: "config/config.yaml"

rule all:
    input:
        "data/tokenized/done.txt"

rule preprocess:
    input:
        config["input"]
    output:
        "data/interim/preprocessed.h5ad"
    shell:
        "echo preprocess for __PROJECT_NAME__ > {output}"


rule tokenize:
    input:
        "data/interim/preprocessed.h5ad"
    output:
        "data/tokenized/done.txt"
    shell:
        "echo tokenize > {output}"